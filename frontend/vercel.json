{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "public": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ceo-1-34jx.onrender.com/api/:path*"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/static/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "env": {
    "REACT_APP_BACKEND_URL": "https://ceo-1-34jx.onrender.com"
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
